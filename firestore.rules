rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidModel(data) {
      return data.id is string &&
             data.name is string && data.name.size() <= 100 &&
             data.imageUrl is string &&
             data.createdBy == request.auth.uid;
    }

    function isValidGalleryItem(data) {
      return data.id is string &&
             data.url is string &&
             data.timestamp is number;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      // Models collection under user
      match /models/{modelId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidModel(request.resource.data) && request.resource.data.createdAt == request.time;
        allow update: if isOwner(userId) && 
                         isValidModel(request.resource.data) &&
                         request.resource.data.createdBy == resource.data.createdBy;
        allow delete: if isOwner(userId);

        // Gallery subcollection
        match /gallery/{galleryId} {
          allow read: if isOwner(userId);
          allow create, update: if isOwner(userId) && isValidGalleryItem(request.resource.data);
          allow delete: if isOwner(userId);
        }
      }
    }

    // Legacy Models collection (optional, keeping for compatibility if any data exists)
    match /models/{modelId} {
      allow read, write: if false; // Deny all to force migration or focus on user-based path
    }
  }
}
