# Gemini API
GEMINI_API_KEY=

# Google OAuth Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# App
APP_BASE_URL=http://localhost:3000

# 允許的前端來源網域（逗號分隔，如 https://app.example.com,https://admin.example.com）；未設定時預設 localhost:3000
ALLOWED_ORIGINS=

# 每個 IP 每分鐘允許的請求數上限；未設定時預設 60
RATE_LIMIT_PER_MIN=

# Gemini 可用模型白名單（逗號分隔）；未設定時使用程式內建清單
GEMINI_MODEL_ALLOWLIST=

# 後台管理頁存取令牌（E4 將啟用，目前先預留欄位）
ADMIN_TOKEN=

# 🚨 server 端強制認證（stage 28-1）。未設定＝開發模式（不驗身份、全員共用 dev-local 額度）。
# 部署務必設 true；NODE_ENV=production 且未設 true 時 server 會拒絕啟動（P0 部署閘）。
REQUIRE_AUTH=

# 每位使用者每日生成類（生圖/生影片）額度；未設定時預設 200
DAILY_IMAGE_QUOTA=

# 強制登入閘（Vite 前端 env，E4b）；未設定或非 'true'＝不強制登入（本地開發，行為不變）；部署設 'true' 強制登入
VITE_REQUIRE_LOGIN=
